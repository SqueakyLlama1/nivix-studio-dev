{
	"name": "nivix-store",
	"version": "0.2.0",
	"description": "Generic Inventory Management App for Startup Businesses",
	"license": "Apache-2.0",
	"author": "Christian Bone <bone.christian.c@outlook.com>",
	"homepage": "https://www.nivixtech.com/studio",
	"type": "commonjs",
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"dist": "electron-builder --win"
	},
	"build": {
		"artifactName": "NivixStore-${version}-Setup.exe",
		"appId": "com.nivixtech.store",
		"productName": "Nivix Store",
		"copyright": "Copyright (C) 2026 Christian Bone / Nivix Technology",
		"directories": {
			"output": "dist"
		},
		"files": [
			"**/*",
			"!dist/*"
		],
		"win": {
			"target": "nsis",
			"icon": "favicon.ico"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true
		},
		"icon": "build/icon.ico",
		"publish": [
			{
				"provider": "generic",
				"url": "https://downloads.nivixtech.com/studio/release/store/"
			}
		]
	},
	"devDependencies": {
		"@electron/rebuild": "^4.0.4",
		"electron": "^42.4.1",
		"electron-builder": "^26.15.3",
		"npm-check-updates": "^22.2.3"
	},
	"dependencies": {
		"better-sqlite3": "^12.11.1",
		"electron-updater": "^6.8.9"
	}
}
