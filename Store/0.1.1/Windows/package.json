{
	"name": "nivix-store",
	"version": "0.1.1",
	"description": "Basic Inventory Management App for Startup Businesses",
	"license": "Apache-2.0",
	"author": "Christian Bone <bone.christian.c@outlook.com>",
	"homepage": "https://www.nivixtech.com/studio",
	"type": "commonjs",
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"dist": "electron-builder --windows nsis"
	},
	"build": {
		"artifactName": "Store-${version}-Setup.exe",
		"appId": "com.nivixtech.store",
		"productName": "Nivix Store",
		"copyright": "Copyright © 2026 Christian Bone",
		"directories": {
			"output": "dist"
		},
		"files": [
			"**/*",
			"!dist/*"
		],
		"win": {
			"target": "nsis",
			"icon": "build/icon.ico"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true
		},
		"publish": [
			{
				"provider": "generic",
				"url": "https://downloads.nivixtech.com/studio/release/store/"
			}
		]
	},
	"devDependencies": {
		"electron": "^42.5.0",
		"electron-builder": "^26.15.3"
	},
	"dependencies": {
		"electron-updater": "^6.8.9",
		"jquery": "^4.0.0"
	}
}
