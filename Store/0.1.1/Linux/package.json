{
	"name": "nivix-store",
	"version": "0.1.1",
	"description": "Basic Inventory Management App for Startup Businesses",
	"license": "Apache-2.0",
	"author": "Christian Bone <bone.christian.c@outlook.com>",
	"homepage": "https://www.nivixtech.com/studio",
	"type": "commonjs",
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"dist": "electron-builder --linux"
	},
	"desktopName": "nivix-store.desktop",
	"build": {
		"artifactName": "Store-${version}-Setup.${ext}",
		"appId": "com.nivix.store",
		"productName": "Nivix Store",
		"copyright": "Copyright © 2026 Christian Bone",
		"directories": {
			"output": "dist"
		},
		"files": [
			"**/*",
			"!dist/*"
		],
		"linux": {
			"target": [
				"deb",
				"rpm",
				"AppImage"
			],
			"syncDesktopName": true,
			"icon": "build/icons",
			"category": "Utilities",
			"synopsis": "Nivix Store Inventory Management",
			"description": "The ultimate free and open-source alternative to inventory management",
			"maintainer": "Christian Bone <bone.christian.c@outlook.com>",
			"vendor": "Nivix Technology",
			"mimeTypes": ["application/x-nivix-store"],
			"executableName": "nivix-store"
		},
		"deb": {
			"depends": [
				"nodejs",
				"libgtk-3-0"
			],
			"packageCategory": "utils",
			"priority": "optional"
		},
		"rpm": {
			"depends": [
				"gtk3",
				"nodejs"
			]
		},
		"publish": [
			{
				"provider": "generic",
				"url": "https://downloads.nivixtech.com/studio/release/store/"
			}
		]
	},
	"devDependencies": {
		"electron": "^42.5.0",
		"electron-builder": "^26.15.3"
	},
	"dependencies": {
		"electron-updater": "^6.8.9",
		"jquery": "^4.0.0"
	}
}