{
	"name": "nivix-volt",
	"version": "0.1.0",
	"description": "Electron GUI-Based Project Manager",
	"license": "Apache-2.0",
	"author": "Christian Bone <bone.christian.c@outlook.com>",
	"homepage": "https://www.nivixtech.com/studio",
	"type": "module",
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"dist": "electron-builder --win"
	},
	"build": {
		"artifactName": "Volt-${version}-Setup.exe",
		"appId": "com.nivix.volt",
		"productName": "Nivix Volt",
		"copyright": "Copyright © 2026 Christian Bone",
		"directories": {
			"output": "dist"
		},
		"files": [
			"**/*",
			"!dist/*"
		],
		"win": {
			"target": "nsis",
			"icon": "favicon.ico"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true
		},
		"icon": "build/icon.ico",
		"publish": [
			{
				"provider": "generic",
				"url": "https://cdn.nivixtech.com/studio/release/store/"
			}
		]
	},
	"devDependencies": {
		"electron": "^33.0.0",
		"electron-builder": "^24.13.3"
	},
	"dependencies": {
		"electron-updater": "^6.7.3",
		"jquery": "^3.7.1"
	}
}