{
	"name": "nivix-volt",
	"version": "0.1.0",
	"description": "Electron GUI-Based Project Manager",
	"license": "Apache-2.0",
	"author": "Christian Bone <bone.christian.c@outlook.com>",
	"homepage": "https://www.nivixtech.com/studio",
	"type": "commonjs",
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"dist": "electron-builder --win"
	},
	"build": {
		"artifactName": "Volt-${version}-Setup.exe",
		"appId": "com.nivixtech.volt",
		"productName": "Nivix Volt",
		"copyright": "Copyright (c) 2026 Christian Bone",
		"directories": {
			"output": "dist"
		},
		"files": [
			"**/*",
			"!dist/*"
		],
		"win": {
			"target": "nsis",
			"icon": "favicon.ico"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true
		},
		"icon": "build/icon.ico"
	},
	"devDependencies": {
		"electron": "^42.3.3",
		"electron-builder": "^26.8.1"
	}
}